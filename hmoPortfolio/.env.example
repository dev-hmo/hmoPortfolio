# ===========================================================================
# Environment Variables — Required for Vercel Deployment
# Copy these to Vercel → Project Settings → Environment Variables
# ===========================================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=<app>

# Admin password for the /admin dashboard login
# Use a strong password! Generate with: openssl rand -base64 16
ADMIN_PASSWORD=

# JWT secret for session tokens
# Use a long random string! Generate with: openssl rand -base64 48
JWT_SECRET=

# Admin Stealth (Obfuscation)
# Access your dashboard at /your-secret-path instead of /admin
# Accessing /admin directly will return a 404
ADMIN_SECRET_PATH=hmo-vault-entry-2026
